# Application Settings
PORT=9000
NODE_ENV=production
FRONTEND_URL=https://www.amkov.com
# FRONTEND_URL=http://localhost:3000

# Database
DB_URL=mongodb+srv://<your_db_user>:<your_db_password>@cluster0.iz82zdd.mongodb.net/amkovDB?appName=Cluster0

# Authentication & Security
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_ACCESS_EXPIRES=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES=30d
BCRYPT_SALT_ROUND=10
EXPRESS_SESSION_SECRET=your_express_session_secret_here

# Super Admin Initialization
SUPER_ADMIN_EMAIL=super@gmail.com
SUPER_ADMIN_PASSWORD=your_super_admin_password_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=https://api.amkov.com/api/v1/auth/google/callback

# SSLCommerz Payment Gateway
SSL_STORE_ID=your_ssl_store_id_here
SSL_STORE_PASS=your_ssl_store_password_here
SSL_PAYMENT_API=https://sandbox.sslcommerz.com/gwprocess/v3/api.php
SSL_VALIDATION_API=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php
SSL_IPN_URL=https://api.amkov.com/api/v1/payment/validate-payment

# SSLCommerz Backend Routing URLs
SSL_SUCCESS_BACKEND_URL=https://api.amkov.com/api/v1/payment/success
SSL_FAIL_BACKEND_URL=https://api.amkov.com/api/v1/payment/fail
SSL_CANCEL_BACKEND_URL=https://api.amkov.com/api/v1/payment/cancel

# SSLCommerz Frontend Routing URLs
SSL_SUCCESS_FRONTEND_URL=https://www.amkov.com/payment/success
SSL_FAIL_FRONTEND_URL=https://www.amkov.com/payment/fail
SSL_CANCEL_FRONTEND_URL=https://www.amkov.com/payment/cancel

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# SMTP / Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_smtp_email_here@gmail.com
SMTP_PASS=your_smtp_app_password_here
SMTP_FROM=your_smtp_email_here@gmail.com

# Redis Caching
REDIS_HOST=your_redis_host_url_here
REDIS_PORT=19210
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password_here

# AWS (Amazon Web Services)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=your_aws_s3_bucket_name_here